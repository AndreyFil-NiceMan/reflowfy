{
  "uid": "reflowfy-overview",
  "title": "Reflowfy Overview",
  "tags": [
    "reflowfy"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Jobs / sec by status",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (status) (rate(reflowfy_jobs_processed_total[1m]))",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Records / sec by pipeline",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (pipeline) (rate(reflowfy_records_processed_total[1m]))",
          "legendFormat": "{{pipeline}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Failure rate (5m)",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 0,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.01
              },
              {
                "color": "red",
                "value": 0.05
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(reflowfy_jobs_failed_total[5m])) / clamp_min(sum(rate(reflowfy_jobs_processed_total[5m])), 1)"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Failures / sec by error_type",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 6,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (error_type) (rate(reflowfy_jobs_failed_total[5m]))",
          "legendFormat": "{{error_type}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Active workers",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 18,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(reflowfy_active_workers)"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Job duration p50 / p95 / p99 (s)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(reflowfy_job_processing_duration_seconds_bucket[5m])))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(reflowfy_job_processing_duration_seconds_bucket[5m])))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(reflowfy_job_processing_duration_seconds_bucket[5m])))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Pipeline executions / sec by mode",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 12,
        "y": 16
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (mode) (rate(reflowfy_pipeline_executions_total[5m]))",
          "legendFormat": "{{mode}}"
        }
      ]
    },
    {
      "id": 8,
      "type": "stat",
      "title": "DLQ depth",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 18,
        "y": 16
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "reflowfy_dlq_depth"
        }
      ]
    },
    {
      "id": 9,
      "type": "stat",
      "title": "Logs dropped / sec (should be 0)",
      "gridPos": {
        "h": 6,
        "w": 24,
        "x": 0,
        "y": 24
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 0.001
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "rate(reflowfy_logs_dropped_total[1m])"
        }
      ]
    }
  ]
}
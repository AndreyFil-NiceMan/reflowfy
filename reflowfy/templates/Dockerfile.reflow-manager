ARG PYTHON_IMAGE=python:3.11-slim
FROM ${PYTHON_IMAGE}

WORKDIR /app

# Install Reflowfy
RUN pip install --no-cache-dir reflowfy

# Copy user pipelines and components
COPY pipelines/ pipelines/
COPY sources/ sources/
COPY transformations/ transformations/
COPY destinations/ destinations/

# Environment variables
ENV PYTHONUNBUFFERED=1
ENV PYTHONPATH=/app
ENV PIPELINE_MODULE=pipelines

EXPOSE 8001
CMD ["python", "-m", "reflowfy.reflow_manager.app"]

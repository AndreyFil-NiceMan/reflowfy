FROM python:3.11-slim

WORKDIR /app

# Install Reflowfy
RUN pip install --no-cache-dir reflowfy

# Copy user pipelines
COPY pipelines/ pipelines/

# Environment variables
ENV PYTHONUNBUFFERED=1
ENV PYTHONPATH=/app
ENV PIPELINE_MODULE=pipelines

EXPOSE 8001
CMD ["python", "-m", "reflowfy.reflow_manager.app"]

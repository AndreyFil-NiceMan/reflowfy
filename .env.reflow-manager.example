# Environment Variables for ReflowManager Service

# Database Configuration
DATABASE_URL=postgresql://reflowfy:reflowfy@postgres:5432/reflowfy

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_TOPIC=reflow.jobs

# Rate Limiting
MAX_JOBS_PER_SECOND=100

# Server Configuration
HOST=0.0.0.0
PORT=8001

# Logging
LOG_LEVEL=INFO
